# ArborX spatial search benchmark for AMD GPUs (Kokkos HIP backend)
# Build: docker build -f docker/Dockerfile.arborx-amd -t leo-arborx-amd:latest .
# Requires: leo-base-amd:latest (build with docker/Dockerfile.base-amd first)
# Two-stage build: Kokkos first, then ArborX on top.
# Uses DBSCAN benchmark (requires boost) with synthetic 10M-point data for profiling.

ARG BASE_TAG=latest
FROM leo-hpctoolkit-amd:${BASE_TAG}

ARG GPU_TARGET=gfx942
ARG ROCM_PATH=/opt/rocm

# Install boost (required by DBSCAN benchmark for program_options)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-program-options-dev \
    && rm -rf /var/lib/apt/lists/*

# Stage 1: Build Kokkos with HIP
RUN git clone --depth 1 https://github.com/kokkos/kokkos.git /opt/kokkos-src

RUN mkdir -p /opt/kokkos-build && cd /opt/kokkos-build && \
    cmake /opt/kokkos-src \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DCMAKE_INSTALL_PREFIX=/opt/kokkos \
        -DCMAKE_CXX_COMPILER=${ROCM_PATH}/bin/hipcc \
        -DCMAKE_CXX_FLAGS="-ggdb -fno-omit-frame-pointer" \
        -DKokkos_ENABLE_SERIAL=ON \
        -DKokkos_ENABLE_HIP=ON \
        -DKokkos_ENABLE_ROCTHRUST=OFF \
        -DKokkos_ARCH_AMD_GFX942=ON \
    && make -j$(nproc) && make install

# Stage 2: Build ArborX with HIP-enabled Kokkos (examples + benchmarks)
RUN git clone --depth 1 https://github.com/arborx/ArborX.git /opt/arborx-src && \
    sed -i '/add_subdirectory(raytracing)/d' /opt/arborx-src/examples/CMakeLists.txt

# Copy optimized benchmark files (adds --repeat N support for PC sampling workaround)
COPY benchmarks/arborx/optimized/benchmarks/cluster/dbscan.cpp /opt/arborx-src/benchmarks/cluster/dbscan.cpp
COPY benchmarks/arborx/optimized/benchmarks/cluster/parameters.hpp /opt/arborx-src/benchmarks/cluster/parameters.hpp

RUN mkdir -p /opt/arborx-build && cd /opt/arborx-build && \
    cmake /opt/arborx-src \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DCMAKE_CXX_COMPILER=${ROCM_PATH}/bin/hipcc \
        -DCMAKE_CXX_FLAGS="-ggdb -fno-omit-frame-pointer" \
        -DCMAKE_PREFIX_PATH=/opt/kokkos \
        -DARBORX_ENABLE_ROCTHRUST=OFF \
        -DARBORX_ENABLE_EXAMPLES=ON \
        -DARBORX_ENABLE_BENCHMARKS=ON \
    && make ArborX_Benchmark_DBSCAN.exe -j$(nproc)

ENV PATH="/opt/arborx-build/benchmarks/cluster:${PATH}"
WORKDIR /opt/leo
