# ArborX spatial search benchmark for Intel GPUs (Kokkos SYCL backend)
# Build: docker build -f docker/Dockerfile.arborx-intel -t leo-arborx-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)
# Two-stage build: Kokkos first, then ArborX on top.

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Install ocloc (needed for INTEL_PVC AOT compilation)
RUN apt-get update && apt-get install -y --no-install-recommends \
    intel-ocloc && rm -rf /var/lib/apt/lists/*

# Stage 1: Build Kokkos with SYCL
RUN git clone --depth 1 --branch 4.5.01 https://github.com/kokkos/kokkos.git /opt/kokkos-src

RUN mkdir -p /opt/kokkos-build && cd /opt/kokkos-build && \
    cmake /opt/kokkos-src \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/kokkos \
        -DCMAKE_CXX_COMPILER=icpx \
        -DCMAKE_CXX_FLAGS=-g \
        -DKokkos_ENABLE_SERIAL=ON \
        -DKokkos_ENABLE_SYCL=ON \
        -DKokkos_ARCH_INTEL_PVC=ON \
    && make -j$(nproc) && make install

# Stage 2: Build ArborX with SYCL-enabled Kokkos
RUN git clone --depth 1 https://github.com/arborx/ArborX.git /opt/arborx-src

RUN mkdir -p /opt/arborx-build && cd /opt/arborx-build && \
    cmake /opt/arborx-src \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CXX_COMPILER=icpx \
        -DCMAKE_CXX_FLAGS=-g \
        -DCMAKE_PREFIX_PATH=/opt/kokkos \
        -DARBORX_ENABLE_EXAMPLES=ON \
        -DARBORX_ENABLE_BENCHMARKS=OFF \
    && make -j$(nproc)

ENV PATH="/opt/arborx-build/examples/molecular_dynamics:${PATH}"
WORKDIR /opt/leo
