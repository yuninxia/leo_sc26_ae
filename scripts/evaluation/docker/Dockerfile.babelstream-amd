# BabelStream memory bandwidth benchmark for AMD GPUs (HIP backend)
# Build: docker build -f docker/Dockerfile.babelstream-amd -t leo-babelstream-amd:latest .
# Requires: leo-base-amd:latest (build with docker/Dockerfile.base-amd first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-amd:${BASE_TAG}

ARG GPU_TARGET=gfx942
ARG ROCM_PATH=/opt/rocm

RUN git clone --depth 1 https://github.com/UoB-HPC/BabelStream.git /opt/BabelStream

RUN mkdir -p /opt/babelstream-build && cd /opt/babelstream-build && \
    cmake /opt/BabelStream \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/babelstream \
        -DMODEL=hip \
        -DCMAKE_CXX_COMPILER=${ROCM_PATH}/bin/hipcc \
        -DCMAKE_CXX_FLAGS="--offload-arch=${GPU_TARGET}" \
        -DCXX_EXTRA_FLAGS="-g -fno-omit-frame-pointer" \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/babelstream/bin:${PATH}"
WORKDIR /opt/leo
