# BabelStream memory bandwidth benchmark for Intel GPUs (SYCL backend)
# Build: docker build -f docker/Dockerfile.babelstream-intel -t leo-babelstream-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

RUN git clone --depth 1 https://github.com/UoB-HPC/BabelStream.git /opt/BabelStream

RUN mkdir -p /opt/babelstream-build && cd /opt/babelstream-build && \
    cmake /opt/BabelStream \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/babelstream \
        -DMODEL=sycl2020-acc \
        -DSYCL_COMPILER=ONEAPI-ICPX \
        -DCMAKE_CXX_COMPILER=icpx \
        -DCXX_EXTRA_FLAGS=-g \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/babelstream/bin:${PATH}"
WORKDIR /opt/leo
