# BabelStream memory bandwidth benchmark for NVIDIA GPUs (CUDA backend)
# Build: docker build -f docker/Dockerfile.babelstream-nvidia -t leo-babelstream-nvidia:latest .
# Requires: leo-base-nvidia:latest (build with docker/Dockerfile.base-nvidia first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-nvidia:${BASE_TAG}

ARG GPU_ARCH=90

RUN git clone --depth 1 https://github.com/UoB-HPC/BabelStream.git /opt/BabelStream

RUN mkdir -p /opt/babelstream-build && cd /opt/babelstream-build && \
    cmake /opt/BabelStream \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/babelstream \
        -DMODEL=cuda \
        -DCMAKE_CUDA_COMPILER=/usr/local/cuda/bin/nvcc \
        -DCUDA_ARCH=sm_${GPU_ARCH} \
        -DCUDA_EXTRA_FLAGS="-lineinfo" \
        -DCXX_EXTRA_FLAGS=-g \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/babelstream/bin:${PATH}"
WORKDIR /opt/leo
