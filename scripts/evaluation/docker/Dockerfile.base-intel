# Base infrastructure for Intel GPU evaluation (Data Center Max / Ponte Vecchio)
# Contains: system deps, Python 3.11, uv, meson, cmake, Dyninst, Leo
# HPCToolkit is in a separate layer — see Dockerfile.hpctoolkit-intel
# Build: docker build -f docker/Dockerfile.base-intel -t leo-base-intel:latest .
# Workloads are built separately — see Dockerfile.rajaperf-intel, Dockerfile.llamacpp-intel

FROM intel/oneapi-basekit:2025.1.0-0-devel-ubuntu22.04

ARG DEBIAN_FRONTEND=noninteractive

# ============================================
# System dependencies
# ============================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc-12 g++-12 \
    cmake \
    git \
    wget \
    curl \
    ca-certificates \
    software-properties-common \
    python3 \
    python3-pip \
    python3-venv \
    pkg-config \
    ninja-build \
    libelf-dev \
    libdw-dev \
    libiberty-dev \
    libbz2-dev \
    libxerces-c-dev \
    liblzma-dev \
    libboost-all-dev \
    libtbb-dev \
    libpapi-dev \
    level-zero-dev \
    libigc-dev \
    libigdfcl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3.11 (project requires >=3.11, system has 3.10)
RUN add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-dev python3.11-venv \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN pip3 install --no-cache-dir uv

# Install meson (HPCToolkit uses meson, not cmake)
RUN uv tool install meson

# Install newer cmake (workloads like RAJAPerf require >= 3.24)
RUN uv tool install "cmake>=3.24,<4"

ENV PATH="/root/.local/bin:${PATH}"

# ============================================
# Dyninst (required by HPCToolkit, build from source)
# ============================================
WORKDIR /opt
RUN git clone --depth 1 https://github.com/dyninst/dyninst.git /opt/dyninst-src && \
    mkdir -p /opt/dyninst-build && cd /opt/dyninst-build && \
    cmake /opt/dyninst-src \
        -DCMAKE_INSTALL_PREFIX=/opt/dyninst \
        -DCMAKE_BUILD_TYPE=Release \
    && make -j$(nproc) \
    && make install \
    && rm -rf /opt/dyninst-src /opt/dyninst-build

ENV LD_LIBRARY_PATH="/opt/dyninst/lib:/opt/dyninst/lib64:${LD_LIBRARY_PATH}"

# ============================================
# Leo (analysis tool)
# ============================================
COPY . /opt/leo
WORKDIR /opt/leo
ENV CC=gcc-12
ENV CXX=g++-12
RUN uv sync --python python3.11 \
    --no-install-package cudf-cu13 \
    --no-install-package pylibcudf-cu13 \
    --no-install-package libcudf-cu13 \
    --no-install-package libcudf-cu13-internal \
    --no-install-package cupy-cuda13x \
    --no-install-package rmm-cu13 \
    --no-install-package librmm-cu13 \
    --no-install-package libkvikio-cu13 \
    --no-install-package cuda-bindings \
    --no-install-package cuda-core \
    --no-install-package cuda-pathfinder \
    --no-install-package cuda-python \
    --no-install-package cuda-toolkit \
    --no-install-package numba-cuda \
    --no-install-package nvidia-cuda-cccl \
    --no-install-package nvidia-cuda-crt \
    --no-install-package nvidia-cuda-nvcc \
    --no-install-package nvidia-cuda-nvrtc \
    --no-install-package nvidia-cuda-runtime

# Smoke test moved to Dockerfile.hpctoolkit-intel (needs GED library from GTPin)

# ============================================
# Environment
# ============================================
# Enable Level Zero tracing layer (required for hpcrun PC sampling with GTPin)
ENV ZE_ENABLE_TRACING_LAYER=1
ENV GPU_VENDOR=intel

ENTRYPOINT ["/bin/bash"]
