# HPCToolkit layer for Intel GPU evaluation
# Contains: HPCToolkit built from source (frequently changes)
# Build: docker build -f docker/Dockerfile.hpctoolkit-intel -t leo-hpctoolkit-intel:latest .
# Requires: leo-base-intel:latest (build with Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-base-intel:${BASE_TAG}

# ============================================
# HPCToolkit (build from source with Meson + Ninja)
# ============================================
# Build from yuningxia/hpctoolkit (feature/hidden-stall-metrics branch)
# This branch includes hidden stall metrics support
RUN git clone --depth 1 https://gitlab.com/yuningxia/hpctoolkit.git -b feature/hidden-stall-metrics /opt/hpctoolkit-src

# Disable dyninst subproject wrap to use our system-built dyninst
RUN mv /opt/hpctoolkit-src/subprojects/dyninst.wrap /opt/hpctoolkit-src/subprojects/dyninst.wrap.disabled 2>/dev/null || true

# Create meson native file to locate dependencies
RUN printf "[built-in options]\ncmake_prefix_path = ['/opt/dyninst', '/opt/intel/oneapi']\n" > /opt/hpctoolkit-native.ini

# Build HPCToolkit with Level Zero + GTPin support
# IGA (iga/kv.hpp, libiga64.so) comes from libigc-dev + libigdfcl-dev packages.
# GTPin is downloaded automatically by HPCToolkit's meson wrap (gtpin-4.5.0).
# (oneAPI env vars are already set by the base image)
RUN meson setup \
        --native-file /opt/hpctoolkit-native.ini \
        --prefix=/opt/hpctoolkit \
        --buildtype=release \
        /opt/hpctoolkit-build /opt/hpctoolkit-src \
        -Dlevel0=enabled \
        -Dopencl=enabled \
        -Dpapi=enabled \
        -Dgtpin=enabled \
    && cd /opt/hpctoolkit-build \
    && ninja -j$(nproc) \
    && ninja install

ENV PATH="/opt/hpctoolkit/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/hpctoolkit/lib:/opt/hpctoolkit/lib64:${LD_LIBRARY_PATH}"

# GED library for Leo's Intel disassembler (from GTPin fetched by HPCToolkit's meson wrap)
# Meson wraps extract into the source tree's subprojects/, not the build tree
ENV GED_LIBRARY_PATH="/opt/hpctoolkit-src/subprojects/gtpin-4.5.0/Profilers/Lib/intel64/libged.so"
ENV LD_LIBRARY_PATH="/opt/hpctoolkit-src/subprojects/gtpin-4.5.0/Profilers/Lib/intel64:${LD_LIBRARY_PATH}"

# ============================================
# Smoke test: verify Leo import and Intel GPU analysis (needs GED from GTPin)
# ============================================
WORKDIR /opt/leo
RUN uv run python scripts/analyze_benchmark.py \
    tests/data/pc/intel/hpctoolkit-single.sycloffload.icpx.intelgpu-measurements \
    --arch pvc --top-n 1

ENTRYPOINT ["/bin/bash"]
