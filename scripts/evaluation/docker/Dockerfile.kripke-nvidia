# Kripke discrete ordinates transport benchmark for NVIDIA GPUs
# Build: docker build -f docker/Dockerfile.kripke-nvidia -t leo-kripke-nvidia:latest .
# Requires: leo-hpctoolkit-nvidia:latest

ARG BASE_TAG=latest
FROM leo-hpctoolkit-nvidia:${BASE_TAG}

ARG GPU_ARCH=90

RUN git clone --depth 1 --recursive https://github.com/LLNL/Kripke.git /opt/kripke-src

RUN mkdir -p /opt/kripke-build && cd /opt/kripke-build && \
    cmake /opt/kripke-src \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DENABLE_CUDA=On \
        -DENABLE_CHAI=On \
        -DCHAI_DISABLE_RM=Off \
        -DENABLE_MPI=Off \
        -DENABLE_OPENMP=Off \
        -DCMAKE_CUDA_ARCHITECTURES=${GPU_ARCH} \
        -DCMAKE_CUDA_FLAGS="-lineinfo --expt-extended-lambda --expt-relaxed-constexpr" \
    && make -j$(nproc) \
    && mkdir -p /opt/kripke/bin \
    && (cp kripke.exe /opt/kripke/bin/ 2>/dev/null || find . -name kripke.exe -exec cp {} /opt/kripke/bin/ \;)

ENV PATH="/opt/kripke/bin:${PATH}"
WORKDIR /opt/leo
