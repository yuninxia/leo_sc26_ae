# llama.cpp workload for AMD GPUs (HIP/ROCm backend)
# Build: docker build -f docker/Dockerfile.llamacpp-amd -t leo-llamacpp-amd:latest .
# Requires: leo-base-amd:latest (build with docker/Dockerfile.base-amd first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-amd:${BASE_TAG}

ARG GPU_TARGET=gfx942

# llama.cpp requires hipBLAS and rocBLAS for GPU-accelerated matrix operations
RUN apt-get update && apt-get install -y --no-install-recommends \
    hipblas-dev rocblas-dev \
    && rm -rf /var/lib/apt/lists/*

# Pin to b48e80f (tested March 2026, unified across all platforms)
RUN git clone https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp && \
    cd /opt/llama.cpp && git checkout b48e80f

WORKDIR /opt/llama.cpp
RUN HIPCXX="$(hipconfig -l)/clang" HIP_PATH="$(hipconfig -R)" \
    cmake -B build \
        -DGGML_HIP=ON \
        -DGPU_TARGETS=${GPU_TARGET} \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
    && cmake --build build -j$(nproc) \
    && cmake --install build --prefix /opt/llamacpp

ENV PATH="/opt/llamacpp/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/llamacpp/lib:${LD_LIBRARY_PATH}"
WORKDIR /opt/leo
