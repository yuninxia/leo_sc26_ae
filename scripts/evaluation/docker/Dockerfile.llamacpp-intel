# llama.cpp workload for Intel GPUs (SYCL/oneAPI backend)
# Build: docker build -f docker/Dockerfile.llamacpp-intel -t leo-llamacpp-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Pin to b48e80f (tested March 2026)
RUN git clone https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp && \
    cd /opt/llama.cpp && git checkout b48e80f

WORKDIR /opt/llama.cpp
# oneAPI env vars (icx, icpx compilers) are already set by the base image
RUN cmake -B build \
        -DGGML_SYCL=ON \
        -DCMAKE_C_COMPILER=icx \
        -DCMAKE_CXX_COMPILER=icpx \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
    && cmake --build build -j$(nproc) \
    && cmake --install build --prefix /opt/llamacpp

ENV PATH="/opt/llamacpp/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/llamacpp/lib:${LD_LIBRARY_PATH}"
WORKDIR /opt/leo
