# llama.cpp LLM inference for NVIDIA GPUs on ARM (GH200, Grace Hopper)
# Build: DOCKER_BUILDKIT=0 docker build -f docker/Dockerfile.llamacpp-nvidia-arm -t leo-llamacpp-nvidia-arm:latest .
# Requires: leo-base-nvidia-arm:latest

ARG BASE_TAG=latest
FROM leo-base-nvidia-arm:${BASE_TAG}

ARG GPU_ARCH=90

# Pin to b48e80f (tested March 2026, unified across all platforms)
RUN git clone https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp && \
    cd /opt/llama.cpp && git checkout b48e80f

WORKDIR /opt/llama.cpp
RUN cmake -B build \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES=${GPU_ARCH} \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DCMAKE_CUDA_FLAGS="-lineinfo" \
    && cmake --build build -j$(nproc) \
    && cmake --install build --prefix /opt/llamacpp

ENV PATH="/opt/llamacpp/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/llamacpp/lib:${LD_LIBRARY_PATH}"
WORKDIR /opt/leo
