# LULESH 2.0 OpenMP offload for AMD GPUs (MI300A)
# Build: docker build -f docker/Dockerfile.lulesh-amd -t leo-lulesh-amd:latest .
# Requires: leo-hpctoolkit-amd:latest

ARG BASE_TAG=latest
FROM leo-hpctoolkit-amd:${BASE_TAG}

ARG GPU_TARGET=gfx942

# Clone LULESH 2.0.2 (contains omp_4.0 OpenMP offload variant)
RUN git clone --depth 1 --branch 2.0.2 https://github.com/LLNL/LULESH.git /opt/lulesh-src/LULESH

# Patch Makefile: the link rule has hardcoded NVIDIA flags; replace with generic $(CXX) $(CXXFLAGS)
RUN cd /opt/lulesh-src/LULESH/omp_4.0 && \
    sed -i 's|$(CXX) -fopenmp=libomp.*-o $@|$(CXX) $(CXXFLAGS) $(OBJECTS2.0) $(LDFLAGS) -lstdc++ -lm -o $@|' Makefile && \
    sed -i 's|-L/usr/local/cuda/nvvm/libdevice||' Makefile

# Build with amdclang++ OpenMP offload to AMD GPU
RUN cd /opt/lulesh-src/LULESH/omp_4.0 && \
    make CXX="amdclang++" \
         CXXFLAGS="-DUSE_MPI=0 -g -O2 -fopenmp -fopenmp-targets=amdgcn-amd-amdhsa -Xopenmp-target=amdgcn-amd-amdhsa -march=${GPU_TARGET}" \
         LDFLAGS="" \
         OMPFLAGS="" && \
    mkdir -p /opt/lulesh/bin && \
    cp lulesh2.0 /opt/lulesh/bin/

ENV PATH="/opt/lulesh/bin:${PATH}"
WORKDIR /opt/leo
