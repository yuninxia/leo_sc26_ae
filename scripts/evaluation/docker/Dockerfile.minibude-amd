# miniBUDE molecular docking benchmark for AMD GPUs (HIP backend)
# Build: docker build -f docker/Dockerfile.minibude-amd -t leo-minibude-amd:latest .
# Requires: leo-base-amd:latest (build with docker/Dockerfile.base-amd first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-amd:${BASE_TAG}

ARG GPU_TARGET=gfx942
ARG ROCM_PATH=/opt/rocm

# Pin to 570f66c (tested March 2026)
RUN git clone https://github.com/UoB-HPC/miniBUDE.git /opt/miniBUDE && \
    cd /opt/miniBUDE && git checkout 570f66c

RUN mkdir -p /opt/minibude-build && cd /opt/minibude-build && \
    cmake /opt/miniBUDE \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/minibude \
        -DMODEL=hip \
        -DCMAKE_CXX_COMPILER=${ROCM_PATH}/bin/hipcc \
        -DCMAKE_CXX_FLAGS="--offload-arch=${GPU_TARGET}" \
        -DCXX_EXTRA_FLAGS="-g -fno-omit-frame-pointer" \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/minibude/bin:${PATH}"
WORKDIR /opt/leo
