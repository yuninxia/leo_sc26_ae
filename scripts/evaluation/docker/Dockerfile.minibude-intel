# miniBUDE molecular docking benchmark for Intel GPUs (SYCL backend)
# Build: docker build -f docker/Dockerfile.minibude-intel -t leo-minibude-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Pin to 570f66c (tested March 2026)
RUN git clone https://github.com/UoB-HPC/miniBUDE.git /opt/miniBUDE && \
    cd /opt/miniBUDE && git checkout 570f66c

# ocloc needed for AOT compilation
RUN apt-get update && apt-get install -y --no-install-recommends intel-ocloc && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/minibude-build && cd /opt/minibude-build && \
    cmake /opt/miniBUDE \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/minibude \
        -DMODEL=sycl \
        -DSYCL_COMPILER=ONEAPI-ICPX \
        -DCMAKE_CXX_COMPILER=icpx \
        -DCXX_EXTRA_FLAGS="-g -fsycl-targets=intel_gpu_pvc" \
        -DCMAKE_EXE_LINKER_FLAGS="-fsycl -fsycl-targets=intel_gpu_pvc" \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/minibude/bin:${PATH}"
WORKDIR /opt/leo
