# miniBUDE molecular docking benchmark for NVIDIA GPUs on ARM (GH200, Grace Hopper)
# Build: docker build -f docker/Dockerfile.minibude-nvidia-arm -t leo-minibude-nvidia-arm:latest .
# Requires: leo-base-nvidia-arm:latest (build with docker/Dockerfile.base-nvidia-arm first)

ARG BASE_TAG=latest
FROM leo-base-nvidia-arm:${BASE_TAG}

ARG GPU_ARCH=90

# Pin to 570f66c (tested March 2026)
RUN git clone https://github.com/UoB-HPC/miniBUDE.git /opt/miniBUDE && \
    cd /opt/miniBUDE && git checkout 570f66c

RUN mkdir -p /opt/minibude-build && cd /opt/minibude-build && \
    cmake /opt/miniBUDE \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/minibude \
        -DMODEL=cuda \
        -DCMAKE_CUDA_COMPILER=/usr/local/cuda/bin/nvcc \
        -DCUDA_ARCH=sm_${GPU_ARCH} \
        -DCUDA_EXTRA_FLAGS="-lineinfo" \
        -DCXX_EXTRA_FLAGS=-g \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/minibude/bin:${PATH}"
WORKDIR /opt/leo
