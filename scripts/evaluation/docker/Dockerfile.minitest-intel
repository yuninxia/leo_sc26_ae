# OpenMP offload minitest for Intel GPUs (single.ompoffload.icpx)
# Build: docker build -f docker/Dockerfile.minitest-intel -t leo-minitest-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)
#
# Compiles a simple OpenMP target offload kernel using icpx (oneAPI DPC++/C++).
# Used to validate HPCToolkit GPU profiling on OpenMP offload programs.

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Source is already at /opt/leo/3rdparty/qahpct/minitest/src/ from base image
RUN cd /opt/leo/3rdparty/qahpct/minitest/src && \
    icpx -g -O2 -fiopenmp -fopenmp-targets=spir64 \
        -o /opt/minitest-bin single.cc ompgpu.cc -lm \
    && mkdir -p /opt/minitest/bin \
    && cp /opt/minitest-bin /opt/minitest/bin/single.ompoffload.icpx.intelgpu

ENV PATH="/opt/minitest/bin:${PATH}"
WORKDIR /opt/leo
