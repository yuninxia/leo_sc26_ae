# OpenMP offload minitest for NVIDIA GPUs on ARM (GH200, Grace Hopper)
# Build: docker build -f docker/Dockerfile.minitest-nvidia-arm -t leo-minitest-nvidia-arm:latest .
# Requires: leo-base-nvidia-arm:latest (build with docker/Dockerfile.base-nvidia-arm first)
#
# Multi-stage build: NVHPC provides nvc++ for OpenMP target offload to NVIDIA GPUs.
# Stage 1 compiles with nvc++, Stage 2 copies binary + runtime libs to the base image.

ARG BASE_TAG=latest
ARG GPU_ARCH=90

# Stage 1: Build with NVHPC (provides nvc++ for OpenMP GPU offload)
FROM nvcr.io/nvidia/nvhpc:24.11-devel-cuda_multi-ubuntu22.04 AS builder

ARG GPU_ARCH=90

COPY 3rdparty/qahpct/minitest/src/ /opt/minitest-src/

WORKDIR /opt/minitest-src
RUN nvc++ -g -O2 -mp -mp=gpu -gpu=cc${GPU_ARCH} \
    -o /opt/single.ompoffload.nvc.cudagpu \
    single.cc ompgpu.cc -lm

# Collect NVHPC runtime libraries needed by the binary
RUN mkdir -p /opt/nvhpc-libs && \
    ldd /opt/single.ompoffload.nvc.cudagpu | \
    awk '/\/opt\/nvidia/{print $3}' | sort -u | \
    xargs -I {} cp -L {} /opt/nvhpc-libs/ && \
    ls -la /opt/nvhpc-libs/

# Stage 2: Leo base image with HPCToolkit
ARG BASE_TAG
FROM leo-base-nvidia-arm:${BASE_TAG}

COPY --from=builder /opt/single.ompoffload.nvc.cudagpu /opt/minitest/bin/single.ompoffload.nvc.cudagpu
COPY --from=builder /opt/nvhpc-libs/ /opt/minitest/lib/

ENV PATH="/opt/minitest/bin:${PATH}"
ENV LD_LIBRARY_PATH="/opt/minitest/lib:${LD_LIBRARY_PATH}"
WORKDIR /opt/leo
