# QuickSilver Monte Carlo particle transport for Intel GPUs (SYCL backend)
# Source: Intel Velocity Bench (https://github.com/oneapi-src/Velocity-Bench)
# Build: docker build -f docker/Dockerfile.quicksilver-intel -t leo-quicksilver-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Install ocloc (needed for PVC AOT compilation)
RUN apt-get update && apt-get install -y --no-install-recommends \
    intel-ocloc && rm -rf /var/lib/apt/lists/*

# Pin to 8284b59 (tested March 2026)
RUN git clone https://github.com/oneapi-src/Velocity-Bench.git /opt/velocity-bench && \
    cd /opt/velocity-bench && git checkout 8284b59

# Build QuickSilver SYCL with debug info for HPCToolkit source mapping
# Note: Must use OVERRIDE_GENERAL_CXX_FLAGS (not CMAKE_CXX_FLAGS) to preserve
# workload-specific flags (-DHAVE_SYCL=1 -DRUN_ON_GPU=1) that the CMake expects.
RUN cd /opt/velocity-bench/QuickSilver/SYCL && \
    mkdir -p build && cd build && \
    CXX=icpx cmake ../ -DGPU_AOT=pvc -DOVERRIDE_GENERAL_CXX_FLAGS="-O3 -fsycl -ffast-math -g" && \
    make -sj && \
    mkdir -p /opt/quicksilver/bin && \
    cp qs /opt/quicksilver/bin/

# Copy benchmark input files
RUN cp -r /opt/velocity-bench/QuickSilver/Examples /opt/quicksilver/examples

ENV PATH="/opt/quicksilver/bin:${PATH}"
WORKDIR /opt/leo
