# QuickSilver Monte Carlo particle transport for NVIDIA GPUs (CUDA backend)
# Source: Intel Velocity Bench (https://github.com/oneapi-src/Velocity-Bench)
# Build: docker build -f docker/Dockerfile.quicksilver-nvidia -t leo-quicksilver-nvidia:latest .
# Requires: leo-base-nvidia:latest (build with docker/Dockerfile.base-nvidia first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-nvidia:${BASE_TAG}

# Install nsys for `nsys profile` per-kernel timing in run_compare_nvidia.sh.
# The CUDA 12.6 apt repo (already enabled in the base image) ships nsys as
# `cuda-nsight-systems-12-6` (NOT `nsight-systems-cli`, which doesn't exist in
# the CUDA repo). Installing it inside the workload layer means reviewers no
# longer need a host /usr/local/cuda bind-mount.
RUN apt-get update && apt-get install -y --no-install-recommends cuda-nsight-systems-12-6 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/local/cuda-12.6/bin/nsys /usr/local/bin/nsys

RUN git clone --depth 1 https://github.com/oneapi-src/Velocity-Bench.git /opt/velocity-bench

# Build QuickSilver CUDA with debug info for HPCToolkit source mapping
RUN cd /opt/velocity-bench/QuickSilver/CUDA/src && \
    sed -i 's/-O3/-O3 -lineinfo/' Makefile && \
    make USE_SM=90 CUDA_PATH=/usr/local/cuda -sj && \
    mkdir -p /opt/quicksilver/bin && \
    cp qs /opt/quicksilver/bin/

# Copy benchmark input files
RUN cp -r /opt/velocity-bench/QuickSilver/Examples /opt/quicksilver/examples

ENV PATH="/opt/quicksilver/bin:${PATH}"
WORKDIR /opt/leo
