# RAJAPerf benchmark workload for NVIDIA GPUs on ARM (GH200, Grace Hopper)
# Build: docker build -f docker/Dockerfile.rajaperf-nvidia-arm -t leo-rajaperf-nvidia-arm:latest .
# Requires: leo-base-nvidia-arm:latest (build with docker/Dockerfile.base-nvidia-arm first)

ARG BASE_TAG=latest
FROM leo-base-nvidia-arm:${BASE_TAG}

ARG GPU_ARCH=90

# Pin to 47aaa7b0 (tested March 2026)
RUN git clone --recursive https://github.com/LLNL/RAJAPerf.git /opt/RAJAPerf && \
    cd /opt/RAJAPerf && git checkout 47aaa7b0

RUN mkdir -p /opt/rajaperf-build && cd /opt/rajaperf-build && \
    cmake /opt/RAJAPerf \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DCMAKE_INSTALL_PREFIX=/opt/rajaperf \
        -DENABLE_CUDA=ON \
        -DENABLE_HIP=OFF \
        -DENABLE_OPENMP=OFF \
        -DRAJA_ENABLE_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES=${GPU_ARCH} \
        -DCUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda \
        -DCMAKE_CUDA_FLAGS="-lineinfo" \
        -DBLT_CXX_STD=c++17 \
        -DCMAKE_CXX_STANDARD=17 \
    && make -j$(nproc) \
    && make install

ENV PATH="/opt/rajaperf/bin:${PATH}"
WORKDIR /opt/leo
