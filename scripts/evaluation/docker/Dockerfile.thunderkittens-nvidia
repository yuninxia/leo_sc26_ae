# ThunderKittens kernel suite for NVIDIA GPUs (H100)
# Standalone profiling drivers for HPCToolkit PC sampling.
# Build: docker build -f docker/Dockerfile.thunderkittens-nvidia -t leo-thunderkittens-nvidia:latest .
# Requires: leo-hpctoolkit-nvidia:latest
#
# ThunderKittens requires CUDA 12.8+ (cudaLaunchAttributePreferredClusterDimension).
# Our base HPCToolkit image uses CUDA 12.6, so we do a multi-stage build:
#   Stage 1: Build ThunderKittens with CUDA 12.8
#   Stage 2: Copy binaries into the HPCToolkit image

# Global ARGs (must be before first FROM for legacy builder)
ARG BASE_TAG=latest

# Stage 1: Build with CUDA 12.8
FROM nvidia/cuda:12.8.0-devel-ubuntu22.04 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 https://github.com/HazyResearch/ThunderKittens.git /opt/thunderkittens

# Copy standalone profiling drivers
COPY scripts/evaluation/docker/thunderkittens/ /opt/thunderkittens/bench/

# Common nvcc flags for all profiling drivers
# -O2 -g1: Moderate optimization with minimal debug info for source attribution
# -lineinfo: DWARF line tables for GPU code (needed by HPCToolkit)
# -DKITTENS_HOPPER -gencode arch=compute_90a,code=sm_90a: H100 target
ENV TK_NVCC_FLAGS="-std=c++20 -O2 -g1 --use_fast_math \
    -lrt -lpthread -ldl -lcuda -lcudadevrt -lcudart_static \
    --expt-extended-lambda --expt-relaxed-constexpr \
    -forward-unknown-to-host-compiler \
    -Xcompiler=-Wno-psabi -Xcompiler=-fno-strict-aliasing \
    -I/opt/thunderkittens/include -I/opt/thunderkittens/prototype \
    -DNDEBUG -lineinfo \
    -DKITTENS_HOPPER -gencode arch=compute_90a,code=sm_90a"

RUN mkdir -p /opt/thunderkittens/bin

# Build upstream BF16 GEMM benchmark (has correctness check)
RUN cd /opt/thunderkittens/kernels/gemm/bf16_h100 && \
    make GPU=H100 && \
    cp bf16_h100_gemm.out /opt/thunderkittens/bin/

# 1. BF16 GEMM profiling driver (no reference GEMM)
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_gemm_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_gemm_bench

# 2. FP8 GEMM profiling driver
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_fp8_gemm_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_fp8_gemm_bench

# 3. Multi-Head Attention (LCF pipeline)
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_attn_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_attn_bench

# 4. LayerNorm (fused residual + norm)
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_layernorm_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_layernorm_bench

# 5. Rotary Position Embedding (LCSF pipeline)
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_rotary_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_rotary_bench

# 6. Mamba2 SSM (LCSF pipeline)
RUN cd /opt/thunderkittens/bench && \
    nvcc tk_mamba2_bench.cu $TK_NVCC_FLAGS \
        -o /opt/thunderkittens/bin/tk_mamba2_bench

# Stage 2: Copy into HPCToolkit image
FROM leo-hpctoolkit-nvidia:${BASE_TAG}

COPY --from=builder /opt/thunderkittens/bin/ /opt/thunderkittens/bin/

ENV PATH="/opt/thunderkittens/bin:${PATH}"
WORKDIR /opt/leo
