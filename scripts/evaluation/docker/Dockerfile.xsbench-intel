# XSBench nuclear cross-section benchmark for Intel GPUs (SYCL backend)
# Build: docker build -f docker/Dockerfile.xsbench-intel -t leo-xsbench-intel:latest .
# Requires: leo-base-intel:latest (build with docker/Dockerfile.base-intel first)

ARG BASE_TAG=latest
FROM leo-hpctoolkit-intel:${BASE_TAG}

# Pin to ba08e52 (tested March 2026)
RUN git clone https://github.com/ANL-CESAR/XSBench.git /opt/XSBench && \
    cd /opt/XSBench && git checkout ba08e52

# ocloc needed for AOT compilation
RUN apt-get update && apt-get install -y --no-install-recommends intel-ocloc && rm -rf /var/lib/apt/lists/*

RUN cd /opt/XSBench/sycl && \
    make CC=icpx OPTIMIZE=yes \
        CFLAGS="-fsycl -std=c++17 -O3 -g -fsycl-targets=intel_gpu_pvc" \
    && mkdir -p /opt/xsbench/bin \
    && cp XSBench /opt/xsbench/bin/

ENV PATH="/opt/xsbench/bin:${PATH}"
WORKDIR /opt/leo
