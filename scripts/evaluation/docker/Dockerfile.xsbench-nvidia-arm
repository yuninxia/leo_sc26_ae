# XSBench nuclear cross-section benchmark for NVIDIA GPUs on ARM (GH200, Grace Hopper)
# Build: docker build -f docker/Dockerfile.xsbench-nvidia-arm -t leo-xsbench-nvidia-arm:latest .
# Requires: leo-base-nvidia-arm:latest (build with docker/Dockerfile.base-nvidia-arm first)

ARG BASE_TAG=latest
FROM leo-base-nvidia-arm:${BASE_TAG}

ARG GPU_ARCH=90

# Pin to ba08e52 (tested March 2026)
RUN git clone https://github.com/ANL-CESAR/XSBench.git /opt/XSBench && \
    cd /opt/XSBench && git checkout ba08e52

RUN cd /opt/XSBench/cuda && \
    make SM_VERSION=${GPU_ARCH} OPTIMIZE=yes \
        CFLAGS="-Xcompiler -Wall -Xcompiler -O3 -arch=sm_${GPU_ARCH} -std=c++14 -lineinfo -g" \
    && mkdir -p /opt/xsbench/bin \
    && cp XSBench /opt/xsbench/bin/

ENV PATH="/opt/xsbench/bin:${PATH}"
WORKDIR /opt/leo
